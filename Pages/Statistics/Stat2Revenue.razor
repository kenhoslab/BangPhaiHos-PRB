@page "/statistics/revenue"
@attribute [Authorize]

@using HealthCoverage.Models.ViewModels
@using HealthCoverage.Services
@using Microsoft.AspNetCore.Authorization

@inject StatisticsService StatSvc
@inject NavigationManager Nav

<PageTitle>รายได้ — เดือน/ปี</PageTitle>

<div>

    @* ── Page header ──────────────────────────────────────────────────────── *@
    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--text-main)">รายได้ — เดือน/ปี</h4>
            <p class="mb-0 small" style="color:var(--text-sub)">สรุปรายได้รายเดือนแยกตามประเภทสิทธิและสถานะ OPD/IPD</p>
        </div>
    </div>

    @* ── Tab nav ──────────────────────────────────────────────────────────── *@
    <div class="stats-tabs mb-3">
        <a href="/statistics/case-count"       class="@ActiveTab("/statistics/case-count")">จำนวนราย</a>
        <a href="/statistics/revenue"          class="@ActiveTab("/statistics/revenue")">รายได้/เดือน</a>
        <a href="/statistics/avg-revenue"      class="@ActiveTab("/statistics/avg-revenue")">รายได้/ราย</a>
        <a href="/statistics/total-revenue"    class="@ActiveTab("/statistics/total-revenue")">รายได้รวม/ปี</a>
        <a href="/statistics/referrer-monthly" class="@ActiveTab("/statistics/referrer-monthly")">การนำส่ง/เดือน</a>
        <a href="/statistics/referrer-year"    class="@ActiveTab("/statistics/referrer-year")">การนำส่ง/ปี</a>
    </div>

    @* ── Year filter ──────────────────────────────────────────────────────── *@
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <label class="form-label mb-0 fw-semibold" style="color:var(--text-main)">ปีที่แสดง:</label>
        <select class="form-select form-select-sm" style="width:auto"
                @bind="_selectedYear" @bind:after="OnYearChanged">
            @foreach (var y in _years.OrderByDescending(x => x))
            {
                <option value="@y">พ.ศ. @(y + 543)</option>
            }
        </select>
    </div>

    @* ── Loading ──────────────────────────────────────────────────────────── *@
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status"></div>
            <p class="mt-2 small" style="color:var(--text-sub)">กำลังโหลดข้อมูล…</p>
        </div>
    }
    else if (_rows.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>ยังไม่มีข้อมูล
        </div>
    }
    else
    {
        @* ── Stats card ───────────────────────────────────────────────────── *@
        <div class="saas-card p-0">
            <div class="table-responsive">
                <table class="stats-table">
                    <thead>
                        <tr>
                            <th rowspan="2" style="text-align:left;min-width:90px">ปี/เดือน</th>
                            <th colspan="2">ใช้สิทธิ พ.ร.บ.</th>
                            <th colspan="2">ชำระสด</th>
                            <th colspan="2">ยอดใช้ PA</th>
                            <th colspan="2">รายได้/เดือน</th>
                            <th rowspan="2" class="col-grand">รวม</th>
                        </tr>
                        <tr>
                            <th>OPD</th><th>IPD</th>
                            <th>OPD</th><th>IPD</th>
                            <th>OPD</th><th>IPD</th>
                            <th>OPD</th><th>IPD</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _rows)
                        {
                            <tr class="@RowCss(row)">
                                <td>@row.Label</td>
                                @if (row.IsEmpty)
                                {
                                    <td>—</td><td>—</td>
                                    <td>—</td><td>—</td>
                                    <td>—</td><td>—</td>
                                    <td>—</td><td>—</td>
                                    <td class="col-grand">—</td>
                                }
                                else
                                {
                                    <td>@row.PrbOpd.ToString("N0")</td>
                                    <td>@row.PrbIpd.ToString("N0")</td>
                                    <td>@row.CashOpd.ToString("N0")</td>
                                    <td>@row.CashIpd.ToString("N0")</td>
                                    <td>@row.PaOpd.ToString("N0")</td>
                                    <td>@row.PaIpd.ToString("N0")</td>
                                    <td>@row.TotalOpd.ToString("N0")</td>
                                    <td>@row.TotalIpd.ToString("N0")</td>
                                    <td class="col-grand">@row.GrandTotal.ToString("N0")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@code {
    List<RevenueRow> _rows  = new();
    List<int>        _years = new();
    bool             _loading = true;
    int              _selectedYear;

    protected override async Task OnInitializedAsync()
    {
        _years = await StatSvc.GetAvailableYearsAsync();
        if (_years.Count > 0)
            _selectedYear = _years[^1];
        await LoadDataAsync();
    }

    async Task OnYearChanged()
        => await LoadDataAsync();

    async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await StatSvc.GetRevenueMonthlyAsync(_selectedYear);
            _rows  = result.Rows;
            _years = result.Years;
        }
        finally
        {
            _loading = false;
        }
    }

    string RowCss(RevenueRow row)
    {
        if (row.IsTotal)  return "row-total";
        if (row.IsAvg)    return "row-avg";
        if (row.IsEmpty)  return "row-empty";
        return "";
    }

    string ActiveTab(string path)
        => Nav.Uri.Contains(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
