@page "/admin/import"
@attribute [Authorize(Roles = "Admin")]

@inject ExcelImportService ImportService
@inject IDbContextFactory<HealthCoverage.Data.ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>นำเข้าข้อมูล พรบ. — โรงพยาบาลบางไผ่</PageTitle>

<div class="container py-4">

    @* ── หัวข้อ ─────────────────────────────────────────────────── *@
    <div class="d-flex align-items-center mb-4 gap-3">
        <div class="bg-success rounded-3 p-3 text-white">
            <i class="bi bi-cloud-upload fs-3"></i>
        </div>
        <div>
            <h3 class="mb-0 text-success fw-bold">นำเข้าข้อมูล พรบ.</h3>
            <p class="text-muted mb-0 small">อัพโหลดไฟล์ Excel รายเดือน — ระบบจะป้องกันการนำเข้าซ้ำอัตโนมัติ</p>
        </div>
    </div>

    @* ── Alert ──────────────────────────────────────────────────── *@
    @if (_alert is not null)
    {
        <div class="alert @_alert.CssClass alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi @_alert.Icon me-2"></i>
            <strong>@_alert.Title</strong> @_alert.Body
            <button type="button" class="btn-close" @onclick="() => _alert = null"></button>
        </div>
    }

    <div class="row g-4">

        @* ── อัพโหลด ────────────────────────────────────────────── *@
        <div class="col-lg-5">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-file-earmark-excel me-2"></i>อัพโหลดไฟล์ Excel
                </div>
                <div class="card-body">

                    @* Drop zone *@
                    <label class="drop-zone @(_isDragging ? "drop-zone--active" : "")"
                           @ondragenter="OnDragEnter" @ondragleave="OnDragLeave" @ondragover:preventDefault>
                        <div class="drop-zone__content">
                            @if (_state == PageState.Idle)
                            {
                                <i class="bi bi-cloud-upload fs-1 text-success"></i>
                                <p class="mb-1 fw-semibold">ลากไฟล์มาวางที่นี่</p>
                                <p class="text-muted small">หรือคลิกเพื่อเลือกไฟล์ .xlsx</p>
                            }
                            else if (_state == PageState.Parsing)
                            {
                                <div class="spinner-border text-success" role="status"></div>
                                <p class="mt-2 mb-0">กำลังอ่านไฟล์…</p>
                            }
                            else
                            {
                                <i class="bi bi-file-earmark-excel fs-1 text-success"></i>
                                <p class="mb-1 fw-semibold text-truncate" style="max-width:220px">@_fileName</p>
                                <p class="text-muted small mb-0">คลิกเพื่อเลือกไฟล์ใหม่</p>
                            }
                        </div>
                        <InputFile OnChange="OnFileSelected" accept=".xlsx"
                                   class="drop-zone__input"
                                   MaxFileSize="@(20 * 1024 * 1024)" />
                    </label>

                    @* Preview stats *@
                    @if (_preview is not null && _state != PageState.Parsing)
                    {
                        <div class="mt-3">
                            <table class="table table-sm table-borderless mb-0">
                                <tbody>
                                    <tr>
                                        <td class="text-muted">เดือน / ปี</td>
                                        <td class="fw-semibold">
                                            @ThaiMonth(_preview.Month) @(_preview.Year + 543)
                                            (ค.ศ. @_preview.Year)
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">จำนวนแถว</td>
                                        <td class="fw-semibold">@_preview.RecordCount แถว</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">OPD</td>
                                        <td>@_preview.OpdCount ราย — @_preview.OpdTotal.ToString("N2") บาท</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">IPD</td>
                                        <td>@_preview.IpdCount ราย — @_preview.IpdTotal.ToString("N2") บาท</td>
                                    </tr>
                                    <tr class="table-success">
                                        <td class="fw-bold">รวม</td>
                                        <td class="fw-bold">@_preview.GrandTotal.ToString("N2") บาท</td>
                                    </tr>
                                </tbody>
                            </table>

                            @if (_preview.Warnings.Count > 0)
                            {
                                <div class="alert alert-warning py-2 mt-2 small">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    <strong>@_preview.Warnings.Count รายการไม่สมบูรณ์</strong>
                                    <ul class="mb-0 mt-1 ps-3">
                                        @foreach (var w in _preview.Warnings.Take(5))
                                        {
                                            <li>@w</li>
                                        }
                                        @if (_preview.Warnings.Count > 5)
                                        {
                                            <li>และอีก @(_preview.Warnings.Count - 5) รายการ…</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* Card footer — buttons *@
                @if (_state == PageState.Previewed || _state == PageState.DuplicateWarning)
                {
                    <div class="card-footer bg-transparent">
                        @if (_state == PageState.DuplicateWarning)
                        {
                            <div class="alert alert-warning py-2 mb-2 small">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                เดือนนี้เคย import ไปแล้ว กรุณาลบข้อมูลเก่าก่อน
                            </div>
                        }

                        <button class="btn btn-success w-100 @(_state == PageState.DuplicateWarning ? "disabled" : "")"
                                @onclick="DoImport"
                                disabled="@(_state == PageState.DuplicateWarning || _state == PageState.Importing)">
                            @if (_state == PageState.Importing)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            <i class="bi bi-cloud-arrow-up me-2"></i>ยืนยัน Import
                        </button>
                        <button class="btn btn-outline-secondary w-100 mt-2" @onclick="ResetPage">
                            ยกเลิก
                        </button>
                    </div>
                }
                @if (_state == PageState.Importing)
                {
                    <div class="card-footer bg-transparent text-center text-muted small">
                        <span class="spinner-border spinner-border-sm me-2 text-success"></span>
                        กำลัง import ข้อมูลลงฐานข้อมูล…
                    </div>
                }
            </div>
        </div>

        @* ── ประวัติการ import ───────────────────────────────────── *@
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-journal-text me-2"></i>ประวัติการนำเข้าข้อมูล</span>
                    <button class="btn btn-sm btn-light" @onclick="LoadHistory">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (_loadingHistory)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-success" role="status"></div>
                        </div>
                    }
                    else if (_imports.Count == 0)
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            ยังไม่มีข้อมูลที่ import
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>เดือน / ปี (พ.ศ.)</th>
                                        <th class="text-center">จำนวนแถว</th>
                                        <th>ไฟล์</th>
                                        <th>Import โดย</th>
                                        <th>วันที่ Import</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var imp in _imports)
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge bg-success fs-6 px-3">
                                                    @ThaiMonth(imp.Month) @(imp.Year + 543)
                                                </span>
                                            </td>
                                            <td class="text-center">@imp.RecordCount</td>
                                            <td class="text-muted small text-truncate" style="max-width:140px">
                                                @imp.FileName
                                            </td>
                                            <td class="small">@(imp.ImportedBy?.UserName ?? "—")</td>
                                            <td class="small text-muted">
                                                @imp.ImportedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => ConfirmDelete(imp)"
                                                        title="ลบข้อมูลเดือนนี้">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Delete confirmation modal ───────────────────────────────────── *@
@if (_deleteTarget is not null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>ยืนยันการลบข้อมูล
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => _deleteTarget = null"></button>
                </div>
                <div class="modal-body">
                    <p>คุณต้องการลบข้อมูลเดือน
                        <strong class="text-danger">@ThaiMonth(_deleteTarget.Month) @(_deleteTarget.Year + 543)</strong>
                        ทั้งหมด <strong>@_deleteTarget.RecordCount แถว</strong> ใช่หรือไม่?
                    </p>
                    <p class="text-muted small mb-0">การลบจะไม่สามารถย้อนกลับได้</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _deleteTarget = null">ยกเลิก</button>
                    <button class="btn btn-danger" @onclick="ExecuteDelete" disabled="@_deleting">
                        @if (_deleting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        ลบข้อมูล
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {

    // ─── State ───────────────────────────────────────────────────────────────

    enum PageState { Idle, Parsing, Previewed, DuplicateWarning, Importing, Done }

    PageState _state = PageState.Idle;
    bool _isDragging;
    string? _fileName;
    byte[]? _fileBytes;                  // เก็บ bytes ไว้สำหรับ import จริง
    ImportResultViewModel? _preview;

    List<PrbImport> _imports = new();
    bool _loadingHistory;

    PrbImport? _deleteTarget;
    bool _deleting;

    AlertModel? _alert;

    // ─── Lifecycle ───────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync() => await LoadHistory();

    // ─── File selection ──────────────────────────────────────────────────────

    async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _alert = null;
        _preview = null;
        _state = PageState.Parsing;
        _fileName = e.File.Name;

        try
        {
            // อ่านไฟล์ทั้งหมดเข้า memory (รองรับไฟล์สูงสุด 20 MB)
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024).CopyToAsync(ms);
            _fileBytes = ms.ToArray();

            // Preview — ไม่บันทึกลง DB
            using var previewStream = new MemoryStream(_fileBytes);
            _preview = await ImportService.PreviewAsync(previewStream, _fileName);

            _state = _preview.IsDuplicate ? PageState.DuplicateWarning : PageState.Previewed;
        }
        catch (Exception ex)
        {
            _alert = AlertModel.Error("อ่านไฟล์ไม่สำเร็จ", ex.Message);
            _state = PageState.Idle;
            _fileBytes = null;
        }
    }

    // ─── Import ──────────────────────────────────────────────────────────────

    async Task DoImport()
    {
        if (_fileBytes is null || _fileName is null) return;

        _state = PageState.Importing;
        _alert = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        string? userId = authState.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        using var stream = new MemoryStream(_fileBytes);
        var result = await ImportService.ImportAsync(stream, _fileName, userId);

        if (result.Success)
        {
            _alert = AlertModel.Success("Import สำเร็จ", result.Message);
            await LoadHistory();
            ResetPage();
        }
        else
        {
            _alert = result.IsDuplicate
                ? AlertModel.Warning("Import ไม่สำเร็จ", result.Message)
                : AlertModel.Error("Import ไม่สำเร็จ", result.Message);
            _state = PageState.Previewed;
        }
    }

    // ─── History ─────────────────────────────────────────────────────────────

    async Task LoadHistory()
    {
        _loadingHistory = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _imports = await db.PrbImports
                .Include(i => i.ImportedBy)
                .OrderByDescending(i => i.Year)
                .ThenByDescending(i => i.Month)
                .ToListAsync();
        }
        finally { _loadingHistory = false; }
    }

    // ─── Delete ──────────────────────────────────────────────────────────────

    void ConfirmDelete(PrbImport imp) => _deleteTarget = imp;

    async Task ExecuteDelete()
    {
        if (_deleteTarget is null) return;
        _deleting = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.PrbImports.FindAsync(_deleteTarget.Id);
            if (entity is not null)
            {
                db.PrbImports.Remove(entity); // cascades to PrbRecord
                await db.SaveChangesAsync();
            }
            _alert = AlertModel.Success("ลบสำเร็จ",
                $"ลบข้อมูลเดือน {ThaiMonth(_deleteTarget.Month)} {_deleteTarget.Year + 543} เรียบร้อย");
            _deleteTarget = null;
            await LoadHistory();
        }
        catch (Exception ex)
        {
            _alert = AlertModel.Error("ลบไม่สำเร็จ", ex.Message);
        }
        finally { _deleting = false; }
    }

    // ─── Drag events ─────────────────────────────────────────────────────────

    void OnDragEnter() => _isDragging = true;
    void OnDragLeave() => _isDragging = false;

    // ─── Helpers ─────────────────────────────────────────────────────────────

    void ResetPage()
    {
        _state = PageState.Idle;
        _fileName = null;
        _fileBytes = null;
        _preview = null;
    }

    static string ThaiMonth(int m) => m switch
    {
        1 => "มกราคม", 2 => "กุมภาพันธ์", 3 => "มีนาคม",
        4 => "เมษายน", 5 => "พฤษภาคม",   6 => "มิถุนายน",
        7 => "กรกฎาคม", 8 => "สิงหาคม",  9 => "กันยายน",
        10 => "ตุลาคม", 11 => "พฤศจิกายน", 12 => "ธันวาคม",
        _ => m.ToString()
    };

    // ─── Alert model ─────────────────────────────────────────────────────────

    record AlertModel(string CssClass, string Icon, string Title, string Body)
    {
        public static AlertModel Success(string t, string b) =>
            new("alert-success",  "bi-check-circle-fill", t, b);
        public static AlertModel Warning(string t, string b) =>
            new("alert-warning",  "bi-exclamation-triangle-fill", t, b);
        public static AlertModel Error(string t, string b) =>
            new("alert-danger",   "bi-x-circle-fill", t, b);
    }
}
