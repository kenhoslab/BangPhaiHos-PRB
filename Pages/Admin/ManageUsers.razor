@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@inject UserManagementService UserSvc
@inject NavigationManager Nav

<PageTitle>จัดการผู้ใช้ — พรบ.</PageTitle>

<div>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1"><i class="bi bi-people-fill me-2 text-success"></i>จัดการผู้ใช้งาน</h4>
            <small class="text-muted">กำหนดสิทธิ์การเข้าถึงเมนูสำหรับผู้ใช้แต่ละคน</small>
        </div>
        <button class="btn btn-success btn-sm" @onclick="OpenCreate">
            <i class="bi bi-person-plus me-1"></i>เพิ่มผู้ใช้
        </button>
    </div>

    <!-- Alert -->
    @if (!string.IsNullOrEmpty(_alertMsg))
    {
        <div class="alert alert-@_alertType alert-dismissible fade show" role="alert">
            @_alertMsg
            <button type="button" class="btn-close" @onclick="() => _alertMsg = null"></button>
        </div>
    }

    <!-- User table -->
    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-success"></div></div>
    }
    else if (_users.Count == 0)
    {
        <div class="text-center text-muted py-5">ไม่มีผู้ใช้ในระบบ</div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ชื่อผู้ใช้</th>
                                <th>อีเมล</th>
                                <th class="text-center">Admin</th>
                                <th class="text-center">นำเข้าข้อมูล</th>
                                <th class="text-center">รายงาน</th>
                                <th class="text-center">Dashboard</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _users)
                            {
                                <tr>
                                    <td>
                                        <i class="bi bi-person-circle me-1 text-secondary"></i>
                                        <strong>@u.UserName</strong>
                                    </td>
                                    <td class="text-muted small">@u.Email</td>

                                    <!-- Admin toggle -->
                                    <td class="text-center">
                                        <div class="form-check form-switch d-flex justify-content-center">
                                            <input class="form-check-input" type="checkbox"
                                                   checked="@u.IsAdmin"
                                                   @onchange="e => ToggleAdmin(u, (bool)e.Value!)" />
                                        </div>
                                    </td>

                                    <!-- Menu permission checkboxes (disabled for admin) -->
                                    @foreach (var key in UserManagementService.AllMenuKeys)
                                    {
                                        <td class="text-center">
                                            <div class="form-check d-flex justify-content-center">
                                                <input class="form-check-input" type="checkbox"
                                                       disabled="@u.IsAdmin"
                                                       checked="@u.MenuKeys.Contains(key)"
                                                       @onchange="e => ToggleMenu(u, key, (bool)e.Value!)" />
                                            </div>
                                        </td>
                                    }

                                    <td class="text-end">
                                        <button class="btn btn-outline-warning btn-sm me-1"
                                                title="รีเซ็ตรหัสผ่าน"
                                                @onclick="() => OpenResetPwd(u)">
                                            <i class="bi bi-key"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm"
                                                title="ลบผู้ใช้"
                                                @onclick="() => OpenDelete(u)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- ── Create User Modal ──────────────────────────────────────────────────── -->
@if (_showCreate)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-dialog-custom">
        <div class="card shadow border-0" style="min-width:380px">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-person-plus me-2"></i>เพิ่มผู้ใช้ใหม่</span>
                <button class="btn-close btn-close-white btn-sm" @onclick="CloseModals"></button>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">ชื่อผู้ใช้</label>
                    <input class="form-control" @bind="_newUser" placeholder="username" />
                </div>
                <div class="mb-3">
                    <label class="form-label">อีเมล</label>
                    <input class="form-control" type="email" @bind="_newEmail" placeholder="email@example.com" />
                </div>
                <div class="mb-3">
                    <label class="form-label">รหัสผ่าน</label>
                    <input class="form-control" type="password" @bind="_newPwd" placeholder="อย่างน้อย 6 ตัวอักษร" />
                </div>
                @if (!string.IsNullOrEmpty(_modalError))
                {
                    <div class="alert alert-danger py-2 small">@_modalError</div>
                }
            </div>
            <div class="card-footer d-flex justify-content-end gap-2">
                <button class="btn btn-secondary btn-sm" @onclick="CloseModals">ยกเลิก</button>
                <button class="btn btn-success btn-sm" @onclick="DoCreate" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    บันทึก
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Reset Password Modal ───────────────────────────────────────────────── -->
@if (_showReset && _targetUser is not null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-dialog-custom">
        <div class="card shadow border-0" style="min-width:360px">
            <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                <span><i class="bi bi-key me-2"></i>รีเซ็ตรหัสผ่าน — @_targetUser.UserName</span>
                <button class="btn-close btn-sm" @onclick="CloseModals"></button>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">รหัสผ่านใหม่</label>
                    <input class="form-control" type="password" @bind="_newPwd" placeholder="อย่างน้อย 6 ตัวอักษร" />
                </div>
                @if (!string.IsNullOrEmpty(_modalError))
                {
                    <div class="alert alert-danger py-2 small">@_modalError</div>
                }
            </div>
            <div class="card-footer d-flex justify-content-end gap-2">
                <button class="btn btn-secondary btn-sm" @onclick="CloseModals">ยกเลิก</button>
                <button class="btn btn-warning btn-sm" @onclick="DoResetPwd" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    บันทึก
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Delete Confirm Modal ───────────────────────────────────────────────── -->
@if (_showDelete && _targetUser is not null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-dialog-custom">
        <div class="card shadow border-0" style="min-width:340px">
            <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-exclamation-triangle me-2"></i>ยืนยันการลบ</span>
                <button class="btn-close btn-close-white btn-sm" @onclick="CloseModals"></button>
            </div>
            <div class="card-body">
                ต้องการลบผู้ใช้ <strong>@_targetUser.UserName</strong> ออกจากระบบ?
                <div class="text-muted small mt-2">การดำเนินการนี้ไม่สามารถย้อนกลับได้</div>
            </div>
            <div class="card-footer d-flex justify-content-end gap-2">
                <button class="btn btn-secondary btn-sm" @onclick="CloseModals">ยกเลิก</button>
                <button class="btn btn-danger btn-sm" @onclick="DoDelete" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    ลบ
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── State ────────────────────────────────────────────────────────────────
    private List<UserRow> _users  = new();
    private bool          _loading = true;
    private bool          _saving  = false;
    private string?       _alertMsg;
    private string        _alertType = "success";

    // Modal state
    private bool     _showCreate = false;
    private bool     _showReset  = false;
    private bool     _showDelete = false;
    private UserRow? _targetUser;
    private string   _newUser  = "";
    private string   _newEmail = "";
    private string   _newPwd   = "";
    private string?  _modalError;

    // ── Lifecycle ────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _users   = await UserSvc.GetUsersAsync();
        _loading = false;
    }

    // ── Toggle admin ─────────────────────────────────────────────────────────

    private async Task ToggleAdmin(UserRow u, bool makeAdmin)
    {
        var (ok, err) = await UserSvc.SetAdminAsync(u.Id, makeAdmin);
        if (ok)
        {
            u.IsAdmin = makeAdmin;
            if (makeAdmin) u.MenuKeys = new HashSet<string>(UserManagementService.AllMenuKeys);
            ShowAlert($"อัปเดตสิทธิ์ {u.UserName} เรียบร้อย", "success");
        }
        else
        {
            ShowAlert(err, "danger");
        }
    }

    // ── Toggle menu permission ────────────────────────────────────────────────

    private async Task ToggleMenu(UserRow u, string key, bool grant)
    {
        if (grant) u.MenuKeys.Add(key);
        else       u.MenuKeys.Remove(key);

        var (ok, err) = await UserSvc.SetMenuPermissionsAsync(u.Id, u.MenuKeys);
        if (ok)
            ShowAlert($"บันทึกสิทธิ์เมนู {u.UserName} เรียบร้อย", "success");
        else
            ShowAlert(err, "danger");
    }

    // ── Create ───────────────────────────────────────────────────────────────

    private void OpenCreate()
    {
        _newUser = _newEmail = _newPwd = "";
        _modalError = null;
        _showCreate = true;
    }

    private async Task DoCreate()
    {
        _modalError = null;
        if (string.IsNullOrWhiteSpace(_newUser) || string.IsNullOrWhiteSpace(_newPwd))
        {
            _modalError = "กรุณากรอกชื่อผู้ใช้และรหัสผ่าน";
            return;
        }
        _saving = true;
        var (ok, err) = await UserSvc.CreateUserAsync(_newUser.Trim(), _newEmail.Trim(), _newPwd);
        _saving = false;
        if (ok)
        {
            CloseModals();
            await LoadAsync();
            ShowAlert($"สร้างผู้ใช้ {_newUser} เรียบร้อย", "success");
        }
        else
        {
            _modalError = err;
        }
    }

    // ── Reset password ───────────────────────────────────────────────────────

    private void OpenResetPwd(UserRow u)
    {
        _targetUser = u;
        _newPwd     = "";
        _modalError = null;
        _showReset  = true;
    }

    private async Task DoResetPwd()
    {
        _modalError = null;
        if (string.IsNullOrWhiteSpace(_newPwd))
        {
            _modalError = "กรุณากรอกรหัสผ่านใหม่";
            return;
        }
        _saving = true;
        var (ok, err) = await UserSvc.ResetPasswordAsync(_targetUser!.Id, _newPwd);
        _saving = false;
        if (ok)
        {
            CloseModals();
            ShowAlert($"รีเซ็ตรหัสผ่าน {_targetUser.UserName} เรียบร้อย", "success");
        }
        else
        {
            _modalError = err;
        }
    }

    // ── Delete ───────────────────────────────────────────────────────────────

    private void OpenDelete(UserRow u)
    {
        _targetUser = u;
        _modalError = null;
        _showDelete = true;
    }

    private async Task DoDelete()
    {
        _saving = true;
        var (ok, err) = await UserSvc.DeleteUserAsync(_targetUser!.Id);
        _saving = false;
        if (ok)
        {
            var name = _targetUser.UserName;
            CloseModals();
            await LoadAsync();
            ShowAlert($"ลบผู้ใช้ {name} เรียบร้อย", "success");
        }
        else
        {
            _modalError = err;
        }
    }

    // ── Helpers ──────────────────────────────────────────────────────────────

    private void CloseModals()
    {
        _showCreate = _showReset = _showDelete = false;
        _targetUser = null;
        _modalError = null;
    }

    private void ShowAlert(string msg, string type)
    {
        _alertMsg  = msg;
        _alertType = type;
    }
}
