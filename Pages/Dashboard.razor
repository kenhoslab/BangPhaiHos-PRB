@page "/dashboard"
@attribute [Authorize]

@inject PrbReportService ReportService

<PageTitle>Dashboard พรบ. — โรงพยาบาลบางไผ่</PageTitle>

<div class="container-fluid py-4">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <div class="d-flex align-items-center mb-4 gap-3">
        <div class="bg-success rounded-3 p-3 text-white">
            <i class="bi bi-speedometer2 fs-3"></i>
        </div>
        <div>
            <h3 class="mb-0 text-success fw-bold">Dashboard พ.ร.บ.</h3>
            <p class="text-muted mb-0 small">สรุปภาพรวมรายได้อุบัติเหตุจราจร — โรงพยาบาลบางไผ่</p>
        </div>
        <div class="ms-auto d-flex gap-2">
            <a class="btn btn-outline-danger btn-sm" href="/report/dashboard/pdf" target="_blank">
                <i class="bi bi-file-earmark-pdf me-1"></i>Export PDF
            </a>
            <button class="btn btn-outline-success btn-sm" @onclick="Refresh">
                <i class="bi bi-arrow-clockwise me-1"></i>รีเฟรช
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status" style="width:3rem;height:3rem"></div>
            <p class="mt-3 text-muted">กำลังโหลดข้อมูล…</p>
        </div>
    }
    else if (_vm is null || _vm.TotalMonthsImported == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            ยังไม่มีข้อมูล กรุณา <a href="/admin/import" class="alert-link">นำเข้าข้อมูล</a> ก่อน
        </div>
    }
    else
    {
        // ── KPI Cards ──────────────────────────────────────────────────────
        <div class="row g-3 mb-4">

            <div class="col-6 col-lg-3">
                <div class="kpi-card kpi-green">
                    <div class="kpi-icon"><i class="bi bi-calendar-check"></i></div>
                    <div class="kpi-body">
                        <div class="kpi-label">เดือนที่นำเข้าแล้ว</div>
                        <div class="kpi-value">@_vm.TotalMonthsImported</div>
                        <div class="kpi-sub">เดือน</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-lg-3">
                <div class="kpi-card kpi-blue">
                    <div class="kpi-icon"><i class="bi bi-people"></i></div>
                    <div class="kpi-body">
                        <div class="kpi-label">ผู้ป่วยรวมทั้งหมด</div>
                        <div class="kpi-value">@_vm.TotalRecords.ToString("N0")</div>
                        <div class="kpi-sub">ราย</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-lg-3">
                <div class="kpi-card kpi-teal">
                    <div class="kpi-icon"><i class="bi bi-cash-stack"></i></div>
                    <div class="kpi-body">
                        <div class="kpi-label">รายได้รวมทั้งหมด</div>
                        <div class="kpi-value">@FormatMillion(_vm.TotalRevenue)</div>
                        <div class="kpi-sub">ล้านบาท</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-lg-3">
                <div class="kpi-card kpi-orange">
                    <div class="kpi-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <div class="kpi-body">
                        <div class="kpi-label">
                            เดือนล่าสุด (@PrbReportService.ThaiMonthShort(_vm.LatestMonth) @(_vm.LatestYear+543))
                        </div>
                        <div class="kpi-value">@_vm.LatestRevenue.ToString("N0")</div>
                        <div class="kpi-sub">
                            OPD @_vm.LatestOpdCount / IPD @_vm.LatestIpdCount ราย
                        </div>
                    </div>
                </div>
            </div>
        </div>

        // ── Revenue breakdown (small row) ───────────────────────────────────
        <div class="row g-3 mb-4">
            @foreach (var (label, amount, icon, color) in new[]
            {
                ("ยอดใช้สิทธิ พรบ.", _vm.TotalPrb,  "bi-shield-check", "#0d6efd"),
                ("ชำระสด",          _vm.TotalCash, "bi-wallet2",       "#198754"),
                ("ยอดใช้ PA",        _vm.TotalPa,   "bi-bank",          "#0dcaf0"),
            })
            {
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body d-flex align-items-center gap-3 py-3">
                            <div class="rounded-3 p-2 text-white" style="background:@color">
                                <i class="bi @icon fs-5"></i>
                            </div>
                            <div>
                                <div class="text-muted small">@label</div>
                                <div class="fw-bold fs-6">@amount.ToString("N2") บาท</div>
                                @if (_vm.TotalRevenue > 0)
                                {
                                    var pct = (double)amount / (double)_vm.TotalRevenue * 100;
                                    <div class="progress mt-1" style="height:5px;width:120px">
                                        <div class="progress-bar" style="width:@pct.ToString("F0")%;background:@color"></div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        // ── Charts row 1: monthly revenue bar + OPD/IPD stacked ────────────
        <div class="row g-3 mb-4">

            <div class="col-xl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-success text-white">
                        <i class="bi bi-bar-chart-fill me-2"></i>รายได้รายเดือน (บาท)
                    </div>
                    <div class="card-body">
                        <ApexChart TItem="MonthlyStat"
                                   Title=""
                                   @ref="_revenueChart"
                                   Options="_revenueOptions"
                                   Height="300">
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="OPD"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.OpdRevenue)"
                                             Color="#086435" />
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="IPD"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.IpdRevenue)"
                                             Color="#00a652" />
                        </ApexChart>
                    </div>
                </div>
            </div>

            <div class="col-xl-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-success text-white">
                        <i class="bi bi-pie-chart-fill me-2"></i>สัดส่วนบริษัทประกัน (รายได้รวม)
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <ApexChart TItem="CompanyBreakdown"
                                   Title=""
                                   Options="_donutOptions"
                                   Height="300">
                            <ApexPointSeries TItem="CompanyBreakdown"
                                             Items="_vm.TopCompanies"
                                             Name="รายได้ (บาท)"
                                             SeriesType="SeriesType.Donut"
                                             XValue="@(c => c.Company)"
                                             YValue="@(c => c.TotalAmount)" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        </div>

        // ── Charts row 2: case-count trend + revenue source stacked ─────────
        <div class="row g-3 mb-4">

            <div class="col-xl-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-success text-white">
                        <i class="bi bi-people-fill me-2"></i>จำนวนผู้ป่วยรายเดือน (OPD vs IPD)
                    </div>
                    <div class="card-body">
                        <ApexChart TItem="MonthlyStat"
                                   Title=""
                                   Options="_countOptions"
                                   Height="260">
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.OpdIpdStats"
                                             Name="OPD"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => (decimal)m.OpdCount)"
                                             Color="#086435" />
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.OpdIpdStats"
                                             Name="IPD"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => (decimal)m.IpdCount)"
                                             Color="#ffc107" />
                        </ApexChart>
                    </div>
                </div>
            </div>

            <div class="col-xl-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-success text-white">
                        <i class="bi bi-layers-fill me-2"></i>แหล่งรายได้รายเดือน (พรบ. / ชำระสด / PA)
                    </div>
                    <div class="card-body">
                        <ApexChart TItem="MonthlyStat"
                                   Title=""
                                   Options="_sourceOptions"
                                   Height="260">
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="ยอดพรบ."
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.PrbAmount)"
                                             Color="#086435" />
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="ชำระสด"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.CashAmount)"
                                             Color="#0dcaf0" />
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="PA"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.PaAmount)"
                                             Color="#ffc107" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        </div>

        // ── Monthly data table ───────────────────────────────────────────────
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <i class="bi bi-table me-2"></i>ตารางสรุปรายเดือน
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>เดือน</th>
                            <th class="text-center">OPD (ราย)</th>
                            <th class="text-center">IPD (ราย)</th>
                            <th class="text-center">รวม (ราย)</th>
                            <th class="text-end">ยอดพรบ. (บาท)</th>
                            <th class="text-end">ชำระสด (บาท)</th>
                            <th class="text-end">PA (บาท)</th>
                            <th class="text-end">รายได้รวม (บาท)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _vm.MonthlyStats.AsEnumerable().Reverse())
                        {
                            <tr>
                                <td>
                                    <a href="/report/monthly?year=@m.Year&month=@m.Month"
                                       class="text-success fw-semibold text-decoration-none">
                                        @PrbReportService.ThaiMonthName(m.Month) @(m.Year + 543)
                                    </a>
                                </td>
                                <td class="text-center">@m.OpdCount</td>
                                <td class="text-center">@m.IpdCount</td>
                                <td class="text-center fw-semibold">@m.TotalCount</td>
                                <td class="text-end">@m.PrbAmount.ToString("N2")</td>
                                <td class="text-end">@m.CashAmount.ToString("N2")</td>
                                <td class="text-end">@m.PaAmount.ToString("N2")</td>
                                <td class="text-end fw-bold text-success">@m.TotalRevenue.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-success fw-bold">
                            <td>รวมทั้งหมด</td>
                            <td class="text-center">@_vm.MonthlyStats.Sum(m => m.OpdCount)</td>
                            <td class="text-center">@_vm.MonthlyStats.Sum(m => m.IpdCount)</td>
                            <td class="text-center">@_vm.TotalRecords</td>
                            <td class="text-end">@_vm.TotalPrb.ToString("N2")</td>
                            <td class="text-end">@_vm.TotalCash.ToString("N2")</td>
                            <td class="text-end">@_vm.TotalPa.ToString("N2")</td>
                            <td class="text-end">@_vm.TotalRevenue.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
</div>

@code {

    DashboardViewModel? _vm;
    bool _loading = true;

    ApexChart<MonthlyStat>? _revenueChart;

    // ── Chart options ─────────────────────────────────────────────────────

    readonly ApexChartOptions<MonthlyStat> _revenueOptions = new()
    {
        Chart = new Chart
        {
            Stacked   = true,
            Toolbar   = new Toolbar { Show = false },
            FontFamily = "Tahoma, sans-serif",
        },
        PlotOptions = new PlotOptions
        {
            Bar = new PlotOptionsBar { BorderRadius = 3, ColumnWidth = "60%" }
        },
        Yaxis = new List<YAxis>
        {
            new YAxis { Labels = new YAxisLabels { Formatter = "function(v){ return (v/1000).toFixed(0)+'K'; }" } }
        },
        Tooltip = new Tooltip
        {
            Y = new TooltipY { Formatter = "function(v){ return v.toLocaleString('th-TH',{minimumFractionDigits:2})+' บาท'; }" }
        },
        Legend = new Legend { Position = LegendPosition.Top },
    };

    readonly ApexChartOptions<CompanyBreakdown> _donutOptions = new()
    {
        Chart  = new Chart { Toolbar = new Toolbar { Show = false }, FontFamily = "Tahoma, sans-serif" },
        Legend = new Legend { Position = LegendPosition.Bottom },
        Tooltip = new Tooltip
        {
            Y = new TooltipY { Formatter = "function(v){ return v.toLocaleString('th-TH',{minimumFractionDigits:2})+' บาท'; }" }
        },
        PlotOptions = new PlotOptions { Pie = new PlotOptionsPie { Donut = new PlotOptionsDonut { Size = "65%" } } },
    };

    readonly ApexChartOptions<MonthlyStat> _countOptions = new()
    {
        Chart = new Chart
        {
            Stacked    = true,
            Toolbar    = new Toolbar { Show = false },
            FontFamily = "Tahoma, sans-serif",
        },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 3 } },
        Legend = new Legend { Position = LegendPosition.Top },
    };

    readonly ApexChartOptions<MonthlyStat> _sourceOptions = new()
    {
        Chart = new Chart
        {
            Stacked    = true,
            Toolbar    = new Toolbar { Show = false },
            FontFamily = "Tahoma, sans-serif",
        },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 3 } },
        Yaxis = new List<YAxis>
        {
            new YAxis { Labels = new YAxisLabels { Formatter = "function(v){ return (v/1000).toFixed(0)+'K'; }" } }
        },
        Legend = new Legend { Position = LegendPosition.Top },
    };

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync() => await LoadData();

    async Task Refresh()
    {
        _loading = true;
        await LoadData();
    }

    async Task LoadData()
    {
        _loading = true;
        _vm = await ReportService.GetDashboardAsync();
        _loading = false;
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    static string FormatMillion(decimal v) => (v / 1_000_000m).ToString("N2");
}
