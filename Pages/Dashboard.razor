@page "/dashboard"
@attribute [Authorize]

@inject PrbReportService ReportService

<PageTitle>Dashboard พรบ. — โรงพยาบาลบางไผ่</PageTitle>

<div>

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <div class="d-flex align-items-center mb-4 gap-3 flex-wrap">
        <div class="ms-auto d-flex gap-2">
            <a class="topbar-btn" href="/report/dashboard/pdf" target="_blank" title="Export PDF"
               style="width:auto;padding:0 14px;gap:6px;text-decoration:none;font-size:.82rem;font-weight:600;color:#dc3545;border-color:#fca5a5;">
                <i class="bi bi-file-earmark-pdf"></i> Export PDF
            </a>
            <button class="topbar-btn" @onclick="Refresh" title="รีเฟรช"
                    style="width:auto;padding:0 14px;gap:6px;font-size:.82rem;font-weight:600;">
                <i class="bi bi-arrow-clockwise"></i> รีเฟรช
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status" style="width:3rem;height:3rem;color:var(--primary)"></div>
            <p class="mt-3" style="color:var(--text-sub)">กำลังโหลดข้อมูล…</p>
        </div>
    }
    else if (_vm is null || _vm.TotalMonthsImported == 0)
    {
        <div class="saas-card p-4 text-center" style="color:var(--text-sub)">
            <i class="bi bi-inbox fs-1 d-block mb-2" style="color:var(--primary);opacity:.5"></i>
            ยังไม่มีข้อมูล กรุณา <a href="/admin/import" style="color:var(--primary)">นำเข้าข้อมูล</a> ก่อน
        </div>
    }
    else
    {
        @* ── KPI Cards ───────────────────────────────────────────────────── *@
        <div class="row g-3 mb-4">

            <div class="col-6 col-lg-3">
                <div class="kpi-card kpi-green">
                    <div class="kpi-icon"><i class="bi bi-calendar-check"></i></div>
                    <div class="kpi-body">
                        <div class="kpi-label">เดือนที่นำเข้าแล้ว</div>
                        <div class="kpi-value">@_vm.TotalMonthsImported</div>
                        <div class="kpi-trend"><i class="bi bi-clock-history"></i> เดือน</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-lg-3">
                <div class="kpi-card kpi-blue">
                    <div class="kpi-icon"><i class="bi bi-people"></i></div>
                    <div class="kpi-body">
                        <div class="kpi-label">ผู้ป่วยรวมทั้งหมด</div>
                        <div class="kpi-value">@_vm.TotalRecords.ToString("N0")</div>
                        <div class="kpi-trend"><i class="bi bi-person-check"></i> ราย</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-lg-3">
                <div class="kpi-card kpi-teal">
                    <div class="kpi-icon"><i class="bi bi-cash-stack"></i></div>
                    <div class="kpi-body">
                        <div class="kpi-label">รายได้รวมทั้งหมด</div>
                        <div class="kpi-value">@FormatMillion(_vm.TotalRevenue)</div>
                        <div class="kpi-trend"><i class="bi bi-graph-up"></i> ล้านบาท</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-lg-3">
                <div class="kpi-card kpi-orange">
                    <div class="kpi-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <div class="kpi-body">
                        <div class="kpi-label">
                            @PrbReportService.ThaiMonthShort(_vm.LatestMonth) @(_vm.LatestYear+543)
                        </div>
                        <div class="kpi-value">@((_vm.LatestRevenue / 1000m).ToString("N0"))K</div>
                        <div class="kpi-trend">
                            <i class="bi bi-activity"></i>
                            OPD @_vm.LatestOpdCount / IPD @_vm.LatestIpdCount
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Revenue breakdown ─────────────────────────────────────────────── *@
        <div class="row g-3 mb-4">
            @foreach (var (label, amount, icon, cls) in new[]
            {
                ("ยอดใช้สิทธิ พรบ.", _vm.TotalPrb,  "bi-shield-check", "kpi-purple"),
                ("ชำระสด",          _vm.TotalCash, "bi-wallet2",       "kpi-blue"),
                ("ยอดใช้ PA",        _vm.TotalPa,   "bi-bank",          "kpi-teal"),
            })
            {
                <div class="col-md-4">
                    <div class="saas-card">
                        <div class="card-body d-flex align-items-center gap-3 py-3 px-4">
                            <div class="kpi-card @cls d-flex align-items-center justify-content-center"
                                 style="width:48px;height:48px;min-height:unset;padding:0;border-radius:14px;flex-shrink:0">
                                <i class="bi @icon fs-5 text-white"></i>
                            </div>
                            <div style="flex:1">
                                <div style="font-size:.75rem;color:var(--text-sub);font-weight:600">@label</div>
                                <div style="font-size:1rem;font-weight:700;color:var(--text-main)">
                                    @amount.ToString("N2") <span style="font-size:.72rem;font-weight:400;color:var(--text-sub)">บาท</span>
                                </div>
                                @if (_vm.TotalRevenue > 0)
                                {
                                    var pct = (double)amount / (double)_vm.TotalRevenue * 100;
                                    <div style="height:4px;background:var(--border);border-radius:4px;margin-top:6px">
                                        <div style="height:4px;border-radius:4px;width:@pct.ToString("F0")%;background:var(--primary)"></div>
                                    </div>
                                }
                            </div>
                            <div style="font-size:.8rem;font-weight:700;color:var(--primary)">
                                @if (_vm.TotalRevenue > 0)
                                {
                                    @(((double)amount / (double)_vm.TotalRevenue * 100).ToString("F1"))@("%")
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Charts + Top Companies ────────────────────────────────────────── *@
        <div class="row g-3 mb-4">

            @* Revenue Bar Chart *@
            <div class="col-xl-8">
                <div class="saas-card h-100">
                    <div class="card-header">
                        <i class="bi bi-bar-chart-fill"></i>
                        รายได้รายเดือน (บาท)
                    </div>
                    <div class="card-body">
                        <ApexChart TItem="MonthlyStat"
                                   Title=""
                                   @ref="_revenueChart"
                                   Options="_revenueOptions"
                                   Height="280">
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="OPD"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.OpdRevenue)"
                                             Color="#059669" />
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="IPD"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.IpdRevenue)"
                                             Color="#34d399" />
                        </ApexChart>
                    </div>
                </div>
            </div>

            @* Top Companies Panel *@
            <div class="col-xl-4">
                <div class="saas-card h-100">
                    <div class="card-header">
                        <i class="bi bi-building"></i>
                        บริษัทประกันภัย Top @_vm.TopCompanies.Count
                    </div>
                    <div class="card-body" style="padding:12px 16px">
                        @{
                            var maxAmt = _vm.TopCompanies.Count > 0 ? _vm.TopCompanies.Max(c => c.TotalAmount) : 1m;
                            var colors = new[]{ "#059669","#34d399","#10b981","#6ee7b7","#f59e0b","#3b82f6","#ec4899","#f97316" };
                        }
                        @foreach (var (c, idx) in _vm.TopCompanies.Select((c,i) => (c, i)))
                        {
                            var pct = maxAmt > 0 ? (double)c.TotalAmount / (double)maxAmt * 100 : 0;
                            var col = colors[idx % colors.Length];
                            <div style="margin-bottom:12px">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span style="font-size:.78rem;font-weight:600;color:var(--text-main);
                                                 max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                                          title="@c.Company">
                                        @c.Company
                                    </span>
                                    <span style="font-size:.75rem;color:var(--text-sub)">
                                        @c.TotalAmount.ToString("N0") ฿
                                    </span>
                                </div>
                                <div style="height:6px;background:var(--border);border-radius:6px">
                                    <div style="height:6px;border-radius:6px;width:@pct.ToString("F0")%;background:@col;transition:width .4s"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ── Chart row 2: OPD/IPD count + revenue source ─────────────────── *@
        <div class="row g-3 mb-4">

            <div class="col-xl-6">
                <div class="saas-card h-100">
                    <div class="card-header">
                        <i class="bi bi-people-fill"></i>
                        จำนวนผู้ป่วยรายเดือน (OPD vs IPD)
                    </div>
                    <div class="card-body">
                        <ApexChart TItem="MonthlyStat"
                                   Title=""
                                   Options="_countOptions"
                                   Height="240">
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.OpdIpdStats"
                                             Name="OPD"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => (decimal)m.OpdCount)"
                                             Color="#059669" />
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.OpdIpdStats"
                                             Name="IPD"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => (decimal)m.IpdCount)"
                                             Color="#f59e0b" />
                        </ApexChart>
                    </div>
                </div>
            </div>

            <div class="col-xl-6">
                <div class="saas-card h-100">
                    <div class="card-header">
                        <i class="bi bi-layers-fill"></i>
                        แหล่งรายได้รายเดือน (พรบ. / ชำระสด / PA)
                    </div>
                    <div class="card-body">
                        <ApexChart TItem="MonthlyStat"
                                   Title=""
                                   Options="_sourceOptions"
                                   Height="240">
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="ยอดพรบ."
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.PrbAmount)"
                                             Color="#059669" />
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="ชำระสด"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.CashAmount)"
                                             Color="#00c48c" />
                            <ApexPointSeries TItem="MonthlyStat"
                                             Items="_vm.MonthlyStats"
                                             Name="PA"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(m => m.Label)"
                                             YValue="@(m => m.PaAmount)"
                                             Color="#f59e0b" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        </div>

        @* ── Monthly summary table ─────────────────────────────────────────── *@
        <div class="saas-card">
            <div class="card-header">
                <i class="bi bi-table"></i>
                ตารางสรุปรายเดือน
            </div>
            <div class="table-responsive">
                <table class="table pipeline-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>เดือน</th>
                            <th class="text-center">OPD (ราย)</th>
                            <th class="text-center">IPD (ราย)</th>
                            <th class="text-center">รวม (ราย)</th>
                            <th class="text-end">ยอดพรบ. (บาท)</th>
                            <th class="text-end">ชำระสด (บาท)</th>
                            <th class="text-end">PA (บาท)</th>
                            <th class="text-end">รายได้รวม (บาท)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _vm.MonthlyStats.AsEnumerable().Reverse())
                        {
                            <tr>
                                <td>
                                    <a href="/report/monthly?year=@m.Year&month=@m.Month"
                                       style="color:var(--primary);font-weight:600;text-decoration:none">
                                        @PrbReportService.ThaiMonthName(m.Month) @(m.Year + 543)
                                    </a>
                                </td>
                                <td class="text-center">
                                    <span class="cell-blue">@m.OpdCount</span>
                                </td>
                                <td class="text-center">
                                    <span class="cell-purple">@m.IpdCount</span>
                                </td>
                                <td class="text-center">
                                    <span class="cell-mint">@m.TotalCount</span>
                                </td>
                                <td class="text-end" style="font-size:.83rem">@m.PrbAmount.ToString("N2")</td>
                                <td class="text-end" style="font-size:.83rem">@m.CashAmount.ToString("N2")</td>
                                <td class="text-end" style="font-size:.83rem">@m.PaAmount.ToString("N2")</td>
                                <td class="text-end">
                                    <span class="cell-mint">@m.TotalRevenue.ToString("N2")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="background:#f5f3ff;font-weight:700">
                            <td style="color:var(--primary)">รวมทั้งหมด</td>
                            <td class="text-center">@_vm.MonthlyStats.Sum(m => m.OpdCount)</td>
                            <td class="text-center">@_vm.MonthlyStats.Sum(m => m.IpdCount)</td>
                            <td class="text-center">@_vm.TotalRecords</td>
                            <td class="text-end">@_vm.TotalPrb.ToString("N2")</td>
                            <td class="text-end">@_vm.TotalCash.ToString("N2")</td>
                            <td class="text-end">@_vm.TotalPa.ToString("N2")</td>
                            <td class="text-end" style="color:var(--primary)">@_vm.TotalRevenue.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
</div>


@code {

    DashboardViewModel? _vm;
    bool _loading = true;

    ApexChart<MonthlyStat>? _revenueChart;

    // ── Chart options ─────────────────────────────────────────────────────

    readonly ApexChartOptions<MonthlyStat> _revenueOptions = new()
    {
        Chart = new Chart
        {
            Stacked   = true,
            Toolbar   = new Toolbar { Show = false },
            FontFamily = "Tahoma, sans-serif",
        },
        PlotOptions = new PlotOptions
        {
            Bar = new PlotOptionsBar { BorderRadius = 3, ColumnWidth = "60%" }
        },
        Yaxis = new List<YAxis>
        {
            new YAxis { Labels = new YAxisLabels { Formatter = "function(v){ return (v/1000).toFixed(0)+'K'; }" } }
        },
        Tooltip = new Tooltip
        {
            Y = new TooltipY { Formatter = "function(v){ return v.toLocaleString('th-TH',{minimumFractionDigits:2})+' บาท'; }" }
        },
        Legend = new Legend { Position = LegendPosition.Top },
    };

    readonly ApexChartOptions<CompanyBreakdown> _donutOptions = new()
    {
        Chart  = new Chart { Toolbar = new Toolbar { Show = false }, FontFamily = "Tahoma, sans-serif" },
        Legend = new Legend { Position = LegendPosition.Bottom },
        Tooltip = new Tooltip
        {
            Y = new TooltipY { Formatter = "function(v){ return v.toLocaleString('th-TH',{minimumFractionDigits:2})+' บาท'; }" }
        },
        PlotOptions = new PlotOptions { Pie = new PlotOptionsPie { Donut = new PlotOptionsDonut { Size = "65%" } } },
    };

    readonly ApexChartOptions<MonthlyStat> _countOptions = new()
    {
        Chart = new Chart
        {
            Stacked    = true,
            Toolbar    = new Toolbar { Show = false },
            FontFamily = "Tahoma, sans-serif",
        },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 3 } },
        Legend = new Legend { Position = LegendPosition.Top },
    };

    readonly ApexChartOptions<MonthlyStat> _sourceOptions = new()
    {
        Chart = new Chart
        {
            Stacked    = true,
            Toolbar    = new Toolbar { Show = false },
            FontFamily = "Tahoma, sans-serif",
        },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 3 } },
        Yaxis = new List<YAxis>
        {
            new YAxis { Labels = new YAxisLabels { Formatter = "function(v){ return (v/1000).toFixed(0)+'K'; }" } }
        },
        Legend = new Legend { Position = LegendPosition.Top },
    };

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync() => await LoadData();

    async Task Refresh()
    {
        _loading = true;
        await LoadData();
    }

    async Task LoadData()
    {
        _loading = true;
        _vm = await ReportService.GetDashboardAsync();
        _loading = false;
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    static string FormatMillion(decimal v) => (v / 1_000_000m).ToString("N2");
}
