<section class="py-5">
    <div class="container">
        <h2 class="text-center text-success mb-4">สาระสุขภาพ</h2>

        <div class="row g-4">
            @foreach (var post in posts)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="@post.ImageUrl" class="card-img-top" alt="@post.Title">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-success">@post.Title</h5>
                            <p class="card-text">@post.Excerpt</p>
                            <a href="@post.Url" class="btn btn-success mt-auto">อ่านเพิ่มเติม</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-4">
            <a href="https://www.bangphaihospital.in.th/สาระสุขภาพ/" class="btn btn-success">ดูเพิ่มเติม</a>
        </div>
    </div>
</section>

