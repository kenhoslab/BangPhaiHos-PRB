@page "/"
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        @{ Nav.NavigateTo("/dashboard", replace: true); }
    </Authorized>
    <NotAuthorized>
        @{ Nav.NavigateTo("/Identity/Account/Login", replace: true); }
    </NotAuthorized>
</AuthorizeView>
