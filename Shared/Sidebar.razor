@inject NavigationManager Nav
@inject IDbContextFactory<HealthCoverage.Data.ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthState
@using Microsoft.AspNetCore.Components.Authorization

<aside class="sidebar @(IsOpen ? "open" : "")">

    <a href="/dashboard" class="sidebar-brand">
        <i class="bi bi-shield-heart-fill"></i>
    </a>

    <AuthorizeView>
        <Authorized>
            <ul class="sidebar-nav">

                <AuthorizeView Roles="Admin" Context="adminCtx">
                    <Authorized>
                        @* Admin — เห็นทุกเมนู *@
                        <li>
                            <a href="/dashboard" class="@Active("/dashboard")" data-tip="Dashboard">
                                <i class="bi bi-speedometer2 nav-icon"></i>
                            </a>
                        </li>
                        <li>
                            <a href="/report/monthly" class="@Active("/report")" data-tip="รายงาน">
                                <i class="bi bi-file-earmark-bar-graph nav-icon"></i>
                            </a>
                        </li>
                        <li>
                            <a href="/statistics/case-count" class="@Active("/statistics")" data-tip="สถิติ">
                                <i class="bi bi-bar-chart-line nav-icon"></i>
                            </a>
                        </li>
                        <hr class="sidebar-divider" />
                        <li>
                            <a href="/admin/import" class="@Active("/admin/import")" data-tip="นำเข้าข้อมูล">
                                <i class="bi bi-cloud-upload nav-icon"></i>
                            </a>
                        </li>
                        <li>
                            <a href="/admin/users" class="@Active("/admin/users")" data-tip="จัดการผู้ใช้">
                                <i class="bi bi-people nav-icon"></i>
                            </a>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        @* Staff — เห็นเฉพาะที่ได้รับสิทธิ์ *@
                        @if (_menuKeys.Contains("dashboard"))
                        {
                            <li>
                                <a href="/dashboard" class="@Active("/dashboard")" data-tip="Dashboard">
                                    <i class="bi bi-speedometer2 nav-icon"></i>
                                </a>
                            </li>
                        }
                        @if (_menuKeys.Contains("report"))
                        {
                            <li>
                                <a href="/report/monthly" class="@Active("/report")" data-tip="รายงาน">
                                    <i class="bi bi-file-earmark-bar-graph nav-icon"></i>
                                </a>
                            </li>
                        }
                        @if (_menuKeys.Contains("statistics"))
                        {
                            <li>
                                <a href="/statistics/case-count" class="@Active("/statistics")" data-tip="สถิติ">
                                    <i class="bi bi-bar-chart-line nav-icon"></i>
                                </a>
                            </li>
                        }
                        @if (_menuKeys.Contains("import"))
                        {
                            <hr class="sidebar-divider" />
                            <li>
                                <a href="/admin/import" class="@Active("/admin/import")" data-tip="นำเข้าข้อมูล">
                                    <i class="bi bi-cloud-upload nav-icon"></i>
                                </a>
                            </li>
                        }
                    </NotAuthorized>
                </AuthorizeView>

            </ul>

            <div class="sidebar-user">
                <div class="sidebar-user-avatar" title="@_userName">@_initials</div>
                <a href="Identity/Account/Logout" title="ออกจากระบบ">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </Authorized>
    </AuthorizeView>
</aside>

<div class="sidebar-overlay @(IsOpen ? "show" : "")" @onclick="Close"></div>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    string _userName = "", _initials = "?";
    HashSet<string> _menuKeys = new();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var user  = state.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userName = user.Identity.Name ?? "";
            _initials = _userName.Length > 0 ? _userName[0].ToString().ToUpper() : "?";
            if (!user.IsInRole("Admin"))
            {
                var id = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (id is not null)
                {
                    await using var db = await DbFactory.CreateDbContextAsync();
                    _menuKeys = (await db.MenuPermissions
                        .Where(p => p.UserId == id).Select(p => p.MenuKey).ToListAsync()).ToHashSet();
                }
            }
        }
    }

    string Active(string path) =>
        Nav.Uri.Contains(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    async Task Close() => await IsOpenChanged.InvokeAsync(false);
}
