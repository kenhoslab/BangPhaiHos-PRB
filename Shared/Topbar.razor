@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Authorization

<header class="topbar">
    <!-- Hamburger (mobile) -->
    <button class="topbar-btn d-lg-none" @onclick="ToggleSidebar" style="border:none;flex-shrink:0">
        <i class="bi bi-list fs-5"></i>
    </button>

    <!-- Greeting -->
    <AuthorizeView>
        <Authorized>
            <div class="topbar-greeting">
                <h5>สวัสดี, @context.User.Identity?.Name <span style="font-size:1.1rem">👋</span></h5>
                <small>@GetPageTitle()</small>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="topbar-greeting">
                <h5>ระบบพ.ร.บ. โรงพยาบาลบางไผ่</h5>
            </div>
        </NotAuthorized>
    </AuthorizeView>

    <!-- Search -->
    <div class="topbar-search">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="ค้นหา..." />
    </div>

    <div class="topbar-actions">
        <!-- Refresh -->
        <a href="javascript:location.reload()" class="topbar-btn" title="รีเฟรช">
            <i class="bi bi-arrow-clockwise"></i>
        </a>

        <!-- User menu -->
        <AuthorizeView>
            <Authorized>
                <div class="topbar-user" @onclick="ToggleDropdown">
                    <div class="topbar-avatar">
                        @(context.User.Identity?.Name?.Length > 0
                            ? context.User.Identity.Name[0].ToString().ToUpper() : "?")
                    </div>
                    <div class="d-none d-sm-block">
                        <div class="topbar-username">@context.User.Identity?.Name</div>
                        <div class="topbar-role">
                            @(context.User.IsInRole("Admin") ? "Administrator" : "Staff")
                        </div>
                    </div>
                    <i class="bi bi-chevron-down ms-1" style="font-size:.65rem;color:var(--text-sub)"></i>

                    @if (_dropdownOpen)
                    {
                        <div class="user-dropdown">
                            <a href="/admin/users" @onclick:stopPropagation>
                                <i class="bi bi-person-circle"></i> โปรไฟล์
                            </a>
                            <hr />
                            <a href="Identity/Account/Logout" class="logout" @onclick:stopPropagation>
                                <i class="bi bi-box-arrow-right"></i> ออกจากระบบ
                            </a>
                        </div>
                    }
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</header>

@code {
    [Parameter] public bool SidebarOpen { get; set; }
    [Parameter] public EventCallback<bool> SidebarOpenChanged { get; set; }
    bool _dropdownOpen = false;

    async Task ToggleSidebar() => await SidebarOpenChanged.InvokeAsync(!SidebarOpen);
    void ToggleDropdown() => _dropdownOpen = !_dropdownOpen;

    string GetPageTitle() => Nav.Uri switch
    {
        var u when u.Contains("/dashboard")    => "สรุปภาพรวมรายได้อุบัติเหตุจราจร",
        var u when u.Contains("/report")       => "รายงานรายเดือน พ.ร.บ.",
        var u when u.Contains("/admin/import") => "นำเข้าข้อมูล Excel",
        var u when u.Contains("/admin/users")  => "จัดการผู้ใช้งาน",
        _                                      => "ศูนย์ประสานสิทธิ",
    };
}
